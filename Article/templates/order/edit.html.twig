{% extends 'base.html.twig' %}

{% block title %}Modifier la commande{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header bg-white">
        <h1 class="h3 mb-0">Modifier la commande #{{ order.id }}</h1>
    </div>
    <div class="card-body">
        {{ form_start(form) }}
        {{ form_widget(form) }}
        <button type="submit" class="btn btn-primary mt-3">Mettre à jour</button>
        <a href="{{ path('app_order_index') }}" class="btn btn-secondary mt-3">Annuler</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}