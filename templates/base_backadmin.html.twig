<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}FlahaSmart - Administration{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🌱</text></svg>">
        
        <!-- Bootstrap 5 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- FontAwesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styleproduit.css') }}">
            <style>
                body {
                    background-color: #eef5f0; /* Fond vert très clair demandé */
                    min-height: 100vh;
                    display: flex;
                    flex-direction: column;
                }
                .navbar-flahasmart {
                    background-color: #1a6d36; /* Vert foncé de l'image */
                }
                .navbar-flahasmart .navbar-brand {
                    color: white;
                    font-weight: bold;
                    font-size: 1.5rem;
                }
                .navbar-flahasmart .nav-link {
                    color: rgba(255, 255, 255, 0.85);
                    margin-left: 15px;
                }
                .navbar-flahasmart .nav-link:hover {
                    color: white;
                }
                .admin-wrapper {
                    display: flex;
                    flex: 1;
                }
                .sidebar {
                    width: 250px;
                    background-color: #247c3b; /* Vert de l'image */
                    border-right: none;
                    padding: 20px 0;
                    min-height: calc(100vh - 56px); /* moins la navbar */
                    box-shadow: 2px 0 5px rgba(0,0,0,0.1);
                }
                .sidebar .nav-link {
                    color: rgba(255, 255, 255, 0.85);
                    padding: 12px 20px;
                    font-weight: 500;
                    transition: all 0.2s;
                }
                .sidebar .nav-link i {
                    width: 25px;
                    color: rgba(255, 255, 255, 0.85);
                }
                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    background-color: rgba(255, 255, 255, 0.1);
                    color: #ffffff;
                    border-left: 4px solid #ffffff;
                }
                .sidebar .nav-link:hover i, .sidebar .nav-link.active i {
                    color: #ffffff;
                }
                .main-content {
                    flex: 1;
                    padding: 30px;
                    max-width: none;
                    background-color: #eef5f0;
                }
            </style>
        {% endblock %}
    </head>
    <body>
        <!-- Top Navbar -->
        <nav class="navbar navbar-expand-lg navbar-flahasmart px-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="#"><i class="fa-solid fa-seedling me-2"></i>FlahaSmart</a>
                <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#topNav">
                    <span class="fa fa-bars text-white"></span>
                </button>
               
            </div>
        </nav>
        
        <!-- Wrapper div -->
        <div class="admin-wrapper">
            <!-- Sidebar -->
            <nav class="sidebar d-none d-md-block">
                <div class="nav flex-column">
                    <a class="nav-link" href="{{ path('admin_stock_index') }}">
                        <i class="fa-solid fa-boxes-stacked"></i> Stocks Produits
                    </a>
                    <a class="nav-link" href="{{ path('admin_consommation_index') }}">
                        <i class="fa-solid fa-chart-pie"></i> Consommations
                    </a>
                    <a class="nav-link" href="#">
                        <i class="fa-solid fa-users"></i> Utilisateurs
                    </a>
                    <a class="nav-link" href="#">
                        <i class="fa-solid fa-gear"></i> Paramètres
                    </a>
                </div>
            </nav>

            <!-- Main view container -->
            <main class="main-content">
                <div class="container-fluid">
                    <div class="bg-white p-4 rounded shadow-sm border-top border-success border-4">
                        {% block body %}{% endblock %}
                    </div>
                </div>
            </main>
        </div>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
