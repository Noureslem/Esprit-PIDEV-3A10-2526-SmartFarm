<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}FlahaSmart - Agriculteur{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🧑‍🌾</text></svg>">
        
        <!-- Bootstrap 5 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- FontAwesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styleproduit.css') }}">
            <style>
                body {
                    background-color: #eef5f0; /* Fond vert très clair (comme sur l'image) */
                    min-height: 100vh;
                    display: flex;
                    flex-direction: column;
                }
                .navbar-flahasmart {
                    background-color: #247c3b; /* Vert classique FlahaSmart  */
                }
                .navbar-flahasmart .navbar-brand {
                    color: white;
                    font-weight: bold;
                    font-size: 1.5rem;
                }
                .navbar-flahasmart .nav-link {
                    color: rgba(255, 255, 255, 0.85);
                    margin-left: 15px;
                }
                .navbar-flahasmart .nav-link:hover {
                    color: white;
                }
                .main-content {
                    flex: 1;
                    padding: 30px;
                    max-width: none;
                }
            </style>
        {% endblock %}
    </head>
    <body>
        <!-- Top Navbar -->
        <nav class="navbar navbar-expand-lg navbar-flahasmart px-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="#"><i class="fa-solid fa-seedling me-2"></i>FlahaSmart</a>
                <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#topNav">
                    <span class="fa fa-bars text-white"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="topNav">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" href="{{ path('agriculteur_stock_index') }}">Mes Stocks</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('agriculteur_consommation_index') }}">Mes Consommations</a></li>
                        </ul>
                </div>
            </div>
        </nav>
        
        <!-- Main view container -->
        <main class="main-content">
            <div class="container">
                <div class="bg-white p-4 rounded shadow-sm border-top border-success border-4">
                    {% block body %}{% endblock %}
                </div>
            </div>
        </main>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
